# ═══════════════════════════════════════════════════
# SMART AGRICULTURE BACKEND — .gitignore
# ═══════════════════════════════════════════════════
# Everything listed here is NEVER committed to Git
# This protects secrets and keeps the repo clean
# ═══════════════════════════════════════════════════


# ─── ENVIRONMENT FILES ──────────────────────────────
# .env contains ALL your real secrets
# NEVER commit this — ever
.env

# Local environment overrides
.env.local
.env.development.local
.env.test.local
.env.production.local

# NOTE: .env.example is NOT listed here
# because it is safe to commit (no real values)


# ─── NODE MODULES ───────────────────────────────────
# All installed libraries live here
# Never commit — can be reinstalled with npm install
# This folder can be hundreds of MB
node_modules/


# ─── LOGS ───────────────────────────────────────────
# Log files generated during runtime
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/


# ─── RUNTIME FILES ──────────────────────────────────
# Files created when the process is running
pids/
*.pid
*.seed
*.pid.lock


# ─── BUILD / DIST ───────────────────────────────────
# Compiled or built output (if added later)
dist/
build/


# ─── COVERAGE ───────────────────────────────────────
# Test coverage reports
coverage/
.nyc_output/


# ─── OS FILES ───────────────────────────────────────
# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux system files
*~


# ─── EDITOR FILES ───────────────────────────────────
# VS Code settings (optional — remove if you want
# to share VS Code config with your team)
.vscode/

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/

# Vim swap files
*.swp
*.swo


# ─── OPTIONAL / FUTURE ──────────────────────────────
# SSL certificates (if added later)
*.pem
*.key
*.cert

# Upload folders (if file upload added later)
uploads/

# Documentation output (PDFs will be shared directly)
docs/output/
