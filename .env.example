  # ═══════════════════════════════════════════════════
  # SMART AGRICULTURE BACKEND — ENVIRONMENT TEMPLATE
  # ═══════════════════════════════════════════════════
  #
  # INSTRUCTIONS:
  # 1. Copy this file to .env
  # 2. Fill in your actual values in .env
  # 3. NEVER commit .env to git — it's in .gitignore
  # 4. DO commit .env.example — it's safe (no secrets)

  # ─── SERVER ────────────────────────────────────────
  PORT=5000
  NODE_ENV=development

  # ─── JWT ───────────────────────────────────────────
  # Generate secure random strings for these secrets
  # Use: openssl rand -hex 32
  JWT_SECRET=your_jwt_secret_here
  JWT_EXPIRES_IN=15m
  REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
  REFRESH_TOKEN_EXPIRES_IN=7d

  # ─── MONGODB ───────────────────────────────────────
  # Production database (not used in development)
  # Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
  MONGODB_URI=your_mongodb_connection_string_here

  # ─── OAUTH — GOOGLE ────────────────────────────────
  # Get from: https://console.cloud.google.com/apis/credentials
  GOOGLE_CLIENT_ID=your_google_client_id_here
  GOOGLE_CLIENT_SECRET=your_google_client_secret_here
  GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

  # ─── OAUTH — FACEBOOK ──────────────────────────────
  # Get from: https://developers.facebook.com/apps/
  FACEBOOK_APP_ID=your_facebook_app_id_here
  FACEBOOK_APP_SECRET=your_facebook_app_secret_here
  FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback

  # ─── MQTT ──────────────────────────────────────────
  # Public HiveMQ broker for development
  # Production: Use private broker with authentication
  MQTT_BROKER_URL=mqtt://broker.hivemq.com
  MQTT_TOPIC=smart-agriculture/sensors

  # ─── MAPBOX ────────────────────────────────────────
  # Get from: https://account.mapbox.com/
  # NEVER expose this token in frontend code directly
  MAPBOX_TOKEN=your_mapbox_token_here

  # ─── MAP BOUNDARY ──────────────────────────────────
  # Geographic boundaries for your farm/field area
  # Center point
  MAP_CENTER_LAT=your_center_latitude_here
  MAP_CENTER_LNG=your_center_longitude_here

  # Bounding box edges
  MAP_BOUNDARY_NORTH=your_north_boundary_here
  MAP_BOUNDARY_SOUTH=your_south_boundary_here
  MAP_BOUNDARY_EAST=your_east_boundary_here
  MAP_BOUNDARY_WEST=your_west_boundary_here

  # Default zoom (1=world, 10=city, 15=street level)
  MAP_DEFAULT_ZOOM=13

  # ─── RATE LIMITING ─────────────────────────────────
  # Time window for rate limiting (milliseconds)
  # 900000 = 15 minutes
  RATE_LIMIT_WINDOW_MS=900000

  # Max requests per window (general API routes)
  RATE_LIMIT_MAX_REQUESTS=100

  # Max requests per window (auth routes - stricter)
  AUTH_RATE_LIMIT_MAX=20

  # Max requests per window (OAuth routes - stricter)
  OAUTH_RATE_LIMIT_MAX=10

  # Max requests per window (map token endpoint)
  MAP_RATE_LIMIT_MAX=30

  # ─── COOKIES ───────────────────────────────────────
  # Used for HTTP-only refresh tokens (web clients)
  COOKIE_SECRET=your_cookie_secret_here